#!/usr/bin/env bash
set -euo pipefail

BRANCH=$(git rev-parse --abbrev-ref HEAD)
UPSTREAM="origin/${BRANCH}"

if git rev-parse --verify "$UPSTREAM" &>/dev/null; then
  CHANGED=$(git diff --name-only "$UPSTREAM"...HEAD)
else
  CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null || echo "")
fi

if echo "$CHANGED" | grep -q "packages/shared/"; then
  echo "▸ Shared package changed — linting all apps…"
  for app in server admin web; do
    bun run "lint:${app}" -- --fix || true
    bun run "prettier:${app}" || true
  done
else
  echo "▸ Running lint-staged on changed files…"
  bunx lint-staged
fi

SHARED_CHANGED=$(echo "$CHANGED" | grep -q "packages/shared/" && echo "true" || echo "false")

if [ "$SHARED_CHANGED" = "true" ] || echo "$CHANGED" | grep -q "apps/admin/"; then
  echo "▸ Type-checking admin…"
  (cd apps/admin && tsc -p tsconfig.app.json --noEmit)
fi

if [ "$SHARED_CHANGED" = "true" ] || echo "$CHANGED" | grep -q "apps/server/"; then
  echo "▸ Type-checking server…"
  (cd apps/server && tsc -p tsconfig.json --noEmit)
fi

if [ "$SHARED_CHANGED" = "true" ] || echo "$CHANGED" | grep -q "apps/web/"; then
  echo "▸ Type-checking web…"
  (cd apps/web && tsc -p tsconfig.json --noEmit)
fi

if ! git diff --quiet; then
  echo "▸ Auto-fixed files detected — committing…"
  git add -A
  git commit -m "lint: eslint and prettier auto commit"
fi
