# Build context: repository root
# Railway service config: deploy/railway/web.toml

FROM node:24 AS base-builder

RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:$PATH"

WORKDIR /app

COPY package.json bun.lock ./
COPY tsconfig.base.json ./
COPY packages ./packages
COPY apps ./apps

RUN bun install

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL

RUN bun run --filter web build

FROM node:24

RUN apt-get update && apt-get install -y --no-install-recommends dumb-init && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json bun.lock ./
COPY packages ./packages
COPY apps/web ./apps/web

COPY --from=base-builder /app/apps/web/.next ./apps/web/.next
COPY --from=base-builder /app/node_modules ./node_modules
COPY --from=base-builder /app/apps/web/node_modules ./apps/web/node_modules

ENV NODE_ENV=production

WORKDIR /app/apps/web
CMD ["dumb-init", "node", "node_modules/next/dist/bin/next", "start"]
