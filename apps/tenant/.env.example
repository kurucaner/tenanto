# Tenant portal API (same PropertyOS server as admin)
VITE_API_URL=http://localhost:3001

# Marketing site (Terms of Service / Privacy Policy links on auth pages)
VITE_WEB_APP_URL=http://localhost:3000

# Google Sign-In (same web client ID as admin; leave empty to hide the button)
# VITE_GOOGLE_CLIENT_ID=

# Datadog RUM (optional for local dev — create app at us5.datadoghq.com)
VITE_DD_RUM_APPLICATION_ID=
VITE_DD_CLIENT_TOKEN=
VITE_DD_RUM_PROXY_URL=http://localhost:8082
VITE_DD_ENV=development
VITE_DD_SITE=us5.datadoghq.com

# Phone OTP UI (must match server TENANT_PHONE_AUTH_ENABLED; default off) — deferred UI
# VITE_TENANT_PHONE_AUTH_ENABLED=false

# Stripe publishable key for Checkout / Elements (same platform pk as server STRIPE_PUBLISHABLE_KEY)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...