{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "target": "ES2022",
    "module": "CommonJS",
    "resolveJsonModule": true,
    "lib": ["ESNext"],
    "outDir": "./dist",
    "rootDir": "../../",
    "paths": {
      "@/packages/shared": ["../../packages/shared/src"],
      "@/packages/*": ["../../packages/*"],
      "@/pagination/*": ["./src/pagination/*"],
      "@/admin/*": ["./src/admin/*"],
      "@/auth/*": ["./src/auth/*"],
      "@/constants/*": ["./src/constants/*"],
      "@/db/*": ["./src/db/*"],
      "@/errors/*": ["./src/errors/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/email": ["./src/email"],
      "@/routes/*": ["./src/routes/*"],
      "@/s3/*": ["./src/s3/*"],
      "@/stripe/*": ["./src/stripe/*"],
      "@/push/*": ["./src/push/*"],
      "@/scheduler/*": ["./src/scheduler/*"],
      "@/services/*": ["./src/services/*"],
      "@/ses/*": ["./src/ses/*"],
      "@/sns/*": ["./src/sns/*"],
      "@/queues/*": ["./src/queues/*"],
      "@/test-fixtures/*": ["./src/test-fixtures/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".dist", "src/**/*.test.ts", "src/test-fixtures/**"]
}
