{
  "name": "server",
  "version": "1.0.2",
  "main": "dist/apps/server/src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"bun src/server.ts\"",
    "build": "tsc -p tsconfig.app.json && bunx tsc-alias -p tsconfig.app.json && cp -r templates dist/apps/server/",
    "start": "NODE_ENV=production node dist/apps/server/src/server.js",
    "worker:email": "bun src/workers/tenant-email-worker.cli.ts",
    "worker:email:prod": "NODE_ENV=production node dist/apps/server/src/workers/tenant-email-worker.cli.js",
    "worker:export": "bun src/workers/property-export-worker.cli.ts",
    "worker:export:prod": "NODE_ENV=production node dist/apps/server/src/workers/property-export-worker.cli.js",
    "test": "bun test",
    "lint": "eslint .",
    "prettier": "prettier --write .",
    "setup:minio-notifications": "bash ../../scripts/setup-minio-s3-notifications.sh"
  },
  "dependencies": {
    "@/packages/shared": "workspace:*",
    "@aws-sdk/client-mediaconvert": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.999.0",
    "@aws-sdk/lib-storage": "^3.999.0",
    "@aws-sdk/client-scheduler": "^3.1002.0",
    "@aws-sdk/client-sesv2": "^3.1002.0",
    "@aws-sdk/client-sns": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.999.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "apple-signin-auth": "^2.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.80.2",
    "datadog-winston": "^1.6.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "expo-server-sdk": "^6.0.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "google-auth-library": "^10.5.0",
    "ioredis": "^5.11.1",
    "libphonenumber-js": "^1.13.8",
    "node-cron": "^4.2.1",
    "openai": "^6.45.0",
    "pg": "^8.18.0",
    "sanitize-html": "^2.17.6",
    "semver": "^7.7.4",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/datadog-winston": "^1.0.7",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/sanitize-html": "^2.16.1",
    "nodemon": "^3.1.9",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts"
  }
}
