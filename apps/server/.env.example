# =============================================================================
# PropertyOS API — environment variables
# Copy to apps/server/.env and fill in values.
# See apps/admin/.env.example for the admin SPA (VITE_* vars).
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Required (local)
PORT=3001
NODE_ENV=development
HOST_ENV=local

# Required — generate a long random string for local dev
JWT_SECRET=

# Optional — logging (default: info)
LOG_LEVEL=info

# Production only — public base URL for unsubscribe links, webhooks, Lambda forwards
API_PUBLIC_URL=http://localhost:3001

# CI only — set by GitHub Actions; do not configure locally
# GITHUB_RUN_NUMBER=

# PM2 cluster only — set automatically in Docker; do not configure locally
# NODE_APP_INSTANCE=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# Required (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=propertyos_local
DB_USER=postgres
DB_PASSWORD=postgres

# Note: Railway may provide DATABASE_URL instead; pool.ts currently uses DB_* only.

# -----------------------------------------------------------------------------
# Redis (BullMQ — tenant email + property exports)
# -----------------------------------------------------------------------------

# Optional (local) — use host/port OR a single URL (URL wins when set)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Optional — Railway / managed Redis (overrides REDIS_HOST / REDIS_PORT)
# REDIS_URL=redis://default:secret@127.0.0.1:6379
# REDISHOST=127.0.0.1
# REDISPORT=6379
# REDISUSER=default
# REDISPASSWORD=

# -----------------------------------------------------------------------------
# Object storage — MinIO (local dev) / S3 (production)
# -----------------------------------------------------------------------------

# Required — bucket name (local MinIO bucket or production AWS S3 bucket)
MINIO_BUCKET=propertyos-local

# Local dev only — MinIO connection
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Required in production — also used as S3 region in dev (default: us-east-1)
AWS_REGION=us-east-1

# Production only — real S3 credentials (ignored for storage in dev; MinIO vars used instead)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Required — MinIO webhook auth + unsubscribe tokens + internal callbacks
# Use the same value when running scripts/setup-minio-s3-notifications.sh
AWS_INTERNAL_SECRET=

# -----------------------------------------------------------------------------
# App URLs (CORS, email links)
# -----------------------------------------------------------------------------

# Required — marketing site (unsubscribe, transactional email links)
WEB_APP_URL=http://localhost:3000

# Required — admin SPA (invite links, magic links)
PLATFORM_APP_URL=http://localhost:5173

# Required — tenant portal SPA (portal invite links)
TENANT_APP_URL=http://localhost:5174

# -----------------------------------------------------------------------------
# Auth — social sign-in
# -----------------------------------------------------------------------------

# Required for Google sign-in (admin web)
GOOGLE_WEB_CLIENT_ID=

# Future — mobile clients (not wired in google.ts yet)
# GOOGLE_IOS_CLIENT_ID=
# GOOGLE_ANDROID_CLIENT_ID=

# Apple Sign In uses hardcoded bundle id com.propertyos.app in apple.ts today

# -----------------------------------------------------------------------------
# Email (AWS SES)
# -----------------------------------------------------------------------------

# Production only — uses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above
# FROM address is hardcoded in ses/ses.ts (noreply@propertyos.app)

# -----------------------------------------------------------------------------
# SMS (AWS SNS)
# -----------------------------------------------------------------------------

# Optional — 10DLC / toll-free origination number (E.164)
SNS_SMS_ORIGINATION_NUMBER=

# -----------------------------------------------------------------------------
# Discord webhooks
# -----------------------------------------------------------------------------

# Optional — support request alerts
DISCORD_SUPPORT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Observability (Datadog)
# -----------------------------------------------------------------------------

# Optional — enables Datadog log shipping (non-development HOST_ENV)
DD_API_KEY=

# Optional — Datadog site (Winston transport uses us5 intake region in code)
DD_SITE=us5.datadoghq.com

# -----------------------------------------------------------------------------
# OpenAI — expense CSV import categorization
# -----------------------------------------------------------------------------

# Optional — feature disabled when empty/whitespace
OPENAI_API_KEY=

# =============================================================================
# Feature tunables (optional — defaults shown)
# =============================================================================

# --- Tenant email campaigns (Communications tab) ---

# Max recipients per campaign (default: 500)
# TENANT_EMAIL_CAMPAIGN_MAX_RECIPIENTS=500

# Max HTML body size in bytes (default: 102400)
# TENANT_EMAIL_CAMPAIGN_MAX_BODY_BYTES=102400

# Worker send rate limit — max jobs per window (default: 14 per 1000ms)
# TENANT_EMAIL_CAMPAIGN_RATE_LIMIT_MAX=14
# TENANT_EMAIL_CAMPAIGN_RATE_LIMIT_DURATION_MS=1000

# API create rate limit — max campaigns per window (default: 5 per 15min)
# TENANT_EMAIL_CAMPAIGN_CREATE_RATE_LIMIT_MAX=5
# TENANT_EMAIL_CAMPAIGN_CREATE_RATE_LIMIT_WINDOW_MS=900000

# Non-production recipient cap (default: 50; set 0 to disable dev cap)
# TENANT_EMAIL_CAMPAIGN_DEV_MAX_RECIPIENTS=50

# Failure alert thresholds for observability logs (default: 10 recipients, 20% rate)
# TENANT_EMAIL_CAMPAIGN_FAILURE_ALERT_MIN_RECIPIENTS=10
# TENANT_EMAIL_CAMPAIGN_FAILURE_ALERT_RATE=0.2

# --- Property exports (Exports tab) ---

# Processing timeout before job marked failed (default: 900000 ms = 15 min)
# PROPERTY_EXPORT_PROCESSING_TIMEOUT_MS=900000

# =============================================================================
# Planned — SDK deps present, not read by server source yet
# =============================================================================

# AWS_EVENTBRIDGE_SCHEDULER_LAMBDA_ARN=
# AWS_EVENTBRIDGE_SCHEDULER_EXECUTION_ROLE_ARN=
# MEDIACONVERT_QUEUE_ARN=
# MEDIACONVERT_ROLE_ARN=
# MEDIACONVERT_ENDPOINT=
# MEDIACONVERT_POLL_INTERVAL_MS=15000
# MEDIACONVERT_POLL_TIMEOUT_MS=21600000
# VAULT_STREAMING_WORKER_MODE=ffmpeg
# VAULT_STREAMING_ENCODER=
# VAULT_STREAMING_MEDIACONVERT_ALLOW_DEV=false